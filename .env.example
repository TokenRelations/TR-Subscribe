# Beehiiv (required)
BEEHIIV_API_KEY=

# Beehiiv (recommended)
BEEHIIV_PUBLICATION_ID=

# Beehiiv API behavior (optional)
BEEHIIV_DOUBLE_OPT_OVERRIDE=
# on | off | not_set

BEEHIIV_SEND_WELCOME_EMAIL=
# true | false

BEEHIIV_REACTIVATE_EXISTING=
# true | false

BEEHIIV_AUTOMATION_IDS=
# comma-separated automation ids

BEEHIIV_UTM_SOURCE=

# One True/False custom field per network in Beehiiv (exact field names). Default ON.
BEEHIIV_INTERESTS_AS_BOOLEAN_CUSTOM_FIELDS=
# true | false (default true)

# Comma-separated Beehiiv field names; if unset, uses built-in list (Token Relations, Solana, …).
BEEHIIV_BOOLEAN_NETWORK_FIELD_NAMES=

# Optional: also POST subscription tags after create (usually false if booleans drive segments).
BEEHIIV_APPLY_NETWORK_TAGS=
# true | false (default false)

BEEHIIV_CUSTOM_FIELD_FULL_NAME=
BEEHIIV_CUSTOM_FIELD_ROLE=
# Legacy text blob for networks; only used when BEEHIIV_INTERESTS_AS_BOOLEAN_CUSTOM_FIELDS=false.
BEEHIIV_CUSTOM_FIELD_NETWORKS=

BEEHIIV_IGNORE_ERRORS=
# true — log Beehiiv failures but return HTTP 200 (use sparingly)

SUBSCRIBE_WEBHOOK_URL=

NEXT_PUBLIC_HERO_TITLE=
NEXT_PUBLIC_HERO_SUBTITLE=
NEXT_PUBLIC_FORM_TITLE=
NEXT_PUBLIC_FORM_SUBTITLE=
NEXT_PUBLIC_EMBED_TITLE=
NEXT_PUBLIC_EMBED_SUBTITLE=
NEXT_PUBLIC_LOGO_CDN_ORIGIN=
